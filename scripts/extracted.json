  "rules": {
    "core": [
      {
        "category": "Stratagems",
        "rule": "No stratagems can be stacked in a phase",
        "description": "Single units can no longer have multiple stratagems stacked on them in a phase. Already powerful units will now have to cause havoc on their own without the crutch of stratagems making them punch harder than they should, or making them more survivable than they have any right to be. ",
        "link": "https://www.warhammer-community.com/en-gb/articles/v0fhjy3m/new40k-your-queries-answered/"
      },
      {
        "category": "Stratagems",
        "rule": "Crushing Impact",
        "description": "",
        "link": ""
      },
      {
        "category": "RAPID INGRESS",
        "rule": "1 CP",
        "description": "CORE STRATAGEM Whether by strategic brilliance, technological marvel, or supernatural ritual, there are many ways a commander can hasten the arrival of their troops.",
        "link": ""
      },
      {
        "category": "SMOKE SCREEN",
        "rule": "1 CP",
        "description": "CORE STRATAGEM Even the most skilled marksman will struggle to hit a target veiled behind a cloud of smoke.",
        "link": ""
      },
      {
        "category": "FIRE OVERWATCH",
        "rule": "1 CP",
        "description": "CORE STRATAGEM A hail of gunfire can drive back an approaching enemy. ELIGIBLE IF: As specified by the rule allowing this type of shooting.",
        "link": ""
      },
      {
        "category": "HEROIC INTERVENTION",
        "rule": "1CP / +1CP",
        "description": "CORE STRATAGEM Battle cries ring out as your warriors rush headlong to face the enemy's offensive.",
        "link": ""
      },
      {
        "category": "INTO THE FREY",
        "rule": "1 CP",
        "description": "When making the Charge roll, if the result is greater than 6 (after modifiers), change it to 6.",
        "link": ""
      },
      {
        "category": "COUNTER-OFFENSIVE",
        "rule": "2 CP",
        "description": "CORE STRATAGEM In close-quarters combat, the slightest hesitation can reveal a flaw to be exploited.",
        "link": ""
      }
    ],
    "command": [],
    "movement": [
      {
        "category": "Rotating",
        "rule": "Pivot is removed",
        "description": " Mobile Keyword means a unit can move horizontally through dense terrain. Some especially agile creatures and Vehicles will get it, like Ork Squighog Boyz, while towering Super-heavy Walkers can get it in return for risking battleshock – similar to how they operate now.",
        "link": ""
      }
    ],
